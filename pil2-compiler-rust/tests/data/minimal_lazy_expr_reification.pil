// minimal_lazy_expr_reification.pil
//
// Phase 1 fixture for plan-rustify-pkgen-e2e-0420 lazy expression
// reification (Round 1 repair per Codex Round 0 review).
//
// The fixture uses the multi-instance airtemplate pattern from
// `minimal_proof_scope_hint.pil` so the SECOND airtemplate instance
// sees proof-scope state that the FIRST instance populated. Under the
// current Rust bulk-lift the second instance's
// `air_expression_store` carries proof-scope slots even when the
// second instance never references them; under JS lazy
// `PackedExpressions` packing the unused proof-scope expressions are
// dropped.
//
// Case coverage:
//
// Case 1 - Proof-scope ref USED multiple times by the second
// instance. `direct_global_update_proves(USED_OPID, ...)` runs in
// each airtemplate invocation; the second instance therefore sees
// the first instance's proof-scope payload AND adds its own. Lazy
// reification should share one packed idx per (expr_id, row_offset)
// across the repeated references.
//
// Case 2 - Proof-scope ref NEVER USED. The first instance writes an
// opid MARKER_UNUSED_OPID payload that includes the distinctive
// literal coefficient 987654321. No balancing
// `direct_global_update_assumes(MARKER_UNUSED_OPID, ...)` is declared
// at airgroup scope, and the second instance does NOT re-invoke
// `direct_global_update_proves(MARKER_UNUSED_OPID, ...)`. JS lazy
// packing leaves this payload out of the second instance's per-AIR
// arena; current Rust bulk-lift keeps it, so the marker coefficient
// appears in the decoded pilout.
//
// Case 3 - AIR-local alias chain. `local_alias_1 = cx + cy;
// local_alias_2 = local_alias_1;` are both read inside the
// airtemplate. Lazy reification shares one packed idx for the two
// references.
//
// Case 4 - Row-offset reuse. `shifted_cx = cx';` alias plus an
// inline `cx' + cy === 0;` constraint both read (cx, row_offset=+1).
// Lazy reification shares one packed idx across the two references.

require "std_constants.pil";
require "std_direct.pil";

const int USED_OPID = 4242;
const int MARKER_UNUSED_OPID = 9871234;

// Proof-scope proofval and its soundness constraint, mirrors
// `minimal_proof_scope_hint.pil` so proof-scope deferred handlers
// receive a real `proofvalue` operand.
proofval ps_enable;
ps_enable * (1 - ps_enable);

airtemplate LazyReifyAir(const int N = 2**4,
                         const expr enable_flag = 1,
                         const int emit_marker_unused = 0) {
    col witness cx;
    col witness cy;

    // Case 3 - AIR-local alias chain, both read.
    const expr local_alias_1 = cx + cy;
    const expr local_alias_2 = local_alias_1;
    local_alias_1 === 0;
    local_alias_2 === 0;

    // Case 4 - AIR-local row-offset reuse. Both constraints
    // reference the `shifted_cx = cx'` alias so JS-lazy
    // `(expr_id, row_offset)` reuse semantics collapse them to
    // the same arena idx via the shared `shifted_cx` lift.
    const expr shifted_cx = cx';
    shifted_cx === 0;
    shifted_cx + cy === 0;

    // Case 1 - Used proof-scope payload. Populates the USED_OPID
    // bus; the airgroup's `direct_global_update_assumes(USED_OPID,
    // ...)` on the other side balances it so the proof-scope
    // reification path is fully exercised.
    direct_global_update_proves(USED_OPID, [0, 0, 1, 0, 0, 0, 0, 0],
                                sel: enable_flag,
                                surname: PIOP_SURNAME_DYNAMIC);

    // Case 2 - Unused proof-scope payload with distinctive marker
    // coefficient 987654321 in the expression array. Gated by
    // `emit_marker_unused` so only the first airtemplate instance
    // actually writes this payload; the second instance inherits
    // the proof-scope state from the first and, under lazy
    // reification, should drop it because the second instance
    // never consumes MARKER_UNUSED_OPID and does not re-populate
    // it either.
    if (emit_marker_unused == 1) {
        direct_global_update_proves(MARKER_UNUSED_OPID,
                                    [987654321, 0, 0, 0, 0, 0, 0, 0],
                                    sel: enable_flag,
                                    surname: PIOP_SURNAME_DYNAMIC);
    }
}

airgroup LazyReify {
    // First instance emits the unused marker payload. The second
    // instance inherits the resulting proof-scope state. JS lazy
    // reification drops the inherited slots the second instance
    // does not reference; Rust bulk-lift keeps them.
    LazyReifyAir(N: 2**4, enable_flag: ps_enable, emit_marker_unused: 1);
    LazyReifyAir(N: 2**4, enable_flag: ps_enable, emit_marker_unused: 0);

    // Balance USED_OPID but NOT MARKER_UNUSED_OPID.
    direct_global_update_assumes(USED_OPID, [0, 1, 0, 0, 0, 0, 0, 0],
                                 sel: ps_enable,
                                 surname: PIOP_SURNAME_DYNAMIC);
}
