// minimal_origin_scoped_cross_air.pil
//
// Round 4 (2026-04-19 loop) real cross-AIR collision fixture.
//
// Codex Round 3 review rejected the first version of this
// fixture because the two AIRs were isolated and the test could
// pass even if the serializer mis-resolved foreign origins. This
// version follows Codex's pre-plan sketch
// (`.humanize/skill/2026-04-19_06-05-45-3512560-cb459f7d/output.md`):
// AIR A and AIR B both call `lookup_proves` and `lookup_assumes`
// on the same bus, so the std_lookup proof-scope deferred
// machinery reifies a shared gsum polynomial that actually lives
// in both AIRs' per-AIR expression store. If the serializer
// silently mis-resolves foreign-origin Intermediates by local id,
// AIR B's pilout will carry an Expression that points at AIR A's
// packed index through AIR B's own local allocator (wrong tree).
//
// The fixture intentionally shapes both AIRs so their local
// Intermediate slot ids collide (same first `const expr`), and
// uses different witness column names so the collision is
// observable: AIR A references `a_x`, AIR B references `b_x`;
// the surviving Intermediate expression in B's pilout is an
// assertion that foreign-id resolution is routed correctly.

require "std_lookup.pil";

airtemplate OriginAirA(const int N = 2**4) {
    col witness a_x;
    col witness a_y;
    // Both AIRs mint a `const expr` as their first local expr
    // slot. Under `IdAllocator::push`'s per-AIR reset this lands
    // at local id 0 on both sides. The Intermediate ref the
    // producer emits at the mint site therefore collides on bare
    // local id.
    const expr a_product = a_x * a_y;
    // lookup_proves registers the bus with `[a_product]` as the
    // provable vector, so std_lookup's proof-scope deferred
    // handler includes the AIR-A-minted Intermediate in the
    // compressed gsum polynomial.
    lookup_proves(1234, [a_product]);
}

airtemplate OriginAirB(const int N = 2**4) {
    col witness b_x;
    col witness b_y;
    const expr b_product = b_x * b_y;
    // lookup_assumes on the same opid pulls the AIR-A-minted
    // Intermediate into AIR B's proto expression store via the
    // std_lookup proof-scope Horner reification. The pre-Round-3
    // serializer resolved the foreign id through AIR B's local
    // source_to_pos path; post-Round-3 it must route via
    // (origin_frame_id, id) in `global_intermediate_resolution`
    // or fall through to `Operand::Constant(0)`.
    lookup_assumes(1234, [b_product]);
}

airgroup OriginScopedCrossAir {
    OriginAirA(N: 2**4);
    OriginAirB(N: 2**4);
}
