// minimal_proof_scope_hint.pil
//
// Drives `std_direct::direct_global_update_proves` from the
// proof scope so `std_sum::update_piop_sum(..., update_type =
// SUM_UPDATE_TYPE_GLOBAL)` runs and the deferred handler
// `piop_gsum_issue_global_debug_hints` emits a populated
// proof-scope `@gsum_debug_data_global` entry. This is the
// hint stream the Rust pre-Round-6 grammar bug truncated
// (identifiers like `continue_seq_on_l1` parsed as
// `Statement::Continue` aborted whole airtemplate bodies,
// dropping the `direct_global_update_*` invocations they
// contained and leaving the global hint stream short).
//
// The fixture has two AIRs that each invoke
// `direct_global_update_*` so the proof-scope global hint
// arrays carry > 1 element. The matching test
// (`proof_scope_symbolic_regression.rs`) decodes
// `gsum_debug_data_global` directly and asserts the per-call
// payload preserves the symbolic operand classes the contract
// requires (`type_piop` non-zero where the call says so,
// `opids` non-empty, `num_reps.op = "proofvalue"`).

require "std_constants.pil";
require "std_direct.pil";

const int CONT_OPID = 9001;

airtemplate ProofScopeAir(const int N, const expr enable_flag = 1) {
    col witness a;
    a * (a - 1) === 0;

    // Identifier whose name starts with `continue` to also
    // pin the Round 6 parser-keyword-boundary class. On the
    // pre-Round-6 grammar, the airtemplate body would abort at
    // this `if`, dropping the constraints and hints below.
    const expr continue_seq_check = 1;
    if (continue_seq_check == 1) {
        continue_seq_check * (a - a) === 0;
    }

    // Drive a proof-scope `direct_global_update_proves` from
    // INSIDE the airtemplate body. This mirrors golden Zisk's
    // `dma_64_aligned.pil:363` shape, where the proof-scope
    // global-hint payload is registered while the AIR-template
    // call frame is active. On the pre-Round-7 fix the writes
    // to `proof.std.gsum.hint.{type_piop, opids[][], num_reps}`
    // happen inside the air-scope `self.exprs` / `self.ints`
    // frames and are discarded when the airtemplate exits.
    direct_global_update_proves(CONT_OPID, [0, 0, 1, 0, 0, 0, 0, 0],
                                sel: enable_flag,
                                surname: PIOP_SURNAME_DYNAMIC);
}

// Proof-scope `proofval` so the per-call `sel` parameter
// resolves to a `proofvalue` operand (matches golden Zisk's
// per-AIR `enable_*` proofvals passed to `direct_global_update_*`
// at the airgroup top level).
proofval ps_enable;
ps_enable * (1 - ps_enable);

airgroup MinimalProofScope {
    // Two AIR instances so the airtemplate's
    // `direct_global_update_proves(... sel: enable_flag)` runs
    // twice — once per airtemplate call frame. Each call writes
    // to `proof.std.gsum.hint.num_reps[k]` with a proofval ColRef
    // that must survive the airtemplate-pop boundary.
    ProofScopeAir(N: 2**4, enable_flag: ps_enable);
    ProofScopeAir(N: 2**4, enable_flag: ps_enable);

    // Top-level proof-scope direct_global_update_assumes call.
    direct_global_update_assumes(CONT_OPID, [0, 1, 0, 0, 0, 0, 0, 0],
                                 sel: ps_enable,
                                 surname: PIOP_SURNAME_DYNAMIC);
}
