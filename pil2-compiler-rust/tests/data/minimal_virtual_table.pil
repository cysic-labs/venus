// minimal_virtual_table.pil
//
// Exercises std_virtual_table via the `virtual Table(...)` airgroup
// declaration, which routes through the VirtualTable airtemplate defined
// in std_virtual_table.pil. On the final-proof step that template emits
// the virtual_table_data_global hint with the air_ids / airgroup_ids
// arrays. Our decode.py's air_ids_by_hint surfaces those arrays, so the
// regression guard is concrete.

require "std_constants.pil";
require "std_lookup.pil";
require "std_virtual_table.pil";

airtemplate MinimalVirtualTableConsumer(const int N, const int opid) {
    col witness a;
    lookup_assumes(opid, [a]);
}

airtemplate MinimalVirtualTableProducer(const int N, const int opid) {
    col fixed A = [0..(N-1)];
    col witness mul;
    lookup_proves(opid, [A], mul: mul);
}

airgroup MinimalVirtualTable {
    set_max_num_rows_virtual(1 << 4);
    MinimalVirtualTableConsumer(N: 2**4, opid: 1);
    virtual MinimalVirtualTableProducer(N: 2**4, opid: 1);
}
