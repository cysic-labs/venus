/*
airtemplate AirA(int N = 2**16, int type = 0) {
    col witness a,b,c,d;
    airgroupval aggregate(prod) agvA;
    agvA - a*b*c*d === 0;
}

airtemplate AirB(int N = 2**16) {
    col witness a,b;
    airgroupval aggregate(prod) agvB;
    agvB - a*b === 0;
}
*/
airtemplate AirSum(int N = 2**16) {
    col witness a,b;
    col fixed K = [1,2,3]...;
    airgroupval aggregate(sum) default(0) agvSum;
    agvSum - a*b - 1 === 0;
}

airtemplate AirProd(int N = 2**16) {
    col witness a,b;
    col fixed K1 = [0,1,2,3]...;
    col fixed K2 = [1,2,3]...;
    airgroupval aggregate(prod) default(1) agvProd;
    agvProd - a*b - 2 === 0;
}
/*
airtemplate AirX(int N = 2**16, int enable_sum = 0, int enable_prod = 0) {
    col witness a,b;

    if (enable_sum) {
        airgroupval aggregate(sum) default(0) agvSumX;
        agvSumX - a*b - 3 === 0;
    }

    if (enable_prod) {
        airgroupval aggregate(prod) default(1) agvProdY;
        agvProdY - a*b - 4 === 0;
    }
    a * (1 - b) === 0;
}
*/
/*
airgroup A {
    int rows = 2**3;
    AirA(rows, 0);
}
airgroup B {
    int rows = 2**3;
    AirB(rows, 0);
}
airgroup A2 {
    int rows = 2**3;
    AirA(rows, 0) alias AirA1;
    AirA(rows, 0) alias AirA2;
    AirA(rows, 0) alias AirA3;
}*/
airgroup SumProd {
    int rows = 2**3;
    AirSum(rows);
    AirProd(rows);
}
