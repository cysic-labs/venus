airtemplate ConstExprPrior(int N = 8) {

    col witness a,b;
    col fixed F = [0..N-1];

    const expr p_ab = a + b;
    const expr s_ab = b;
    const expr s_int = 3;
    const expr eq[2][2];

    for (int i = 0; i < 2; ++i) {
        eq[0][i] = foo(p_ab, 2 * (i + 1)) + foo(p_ab, 3 * (i + 1));
        eq[1][i] = foo(s_ab, 2 * (i + 1)) + foo(s_ab, 3 * (i + 1));
    }

    println(eq[0][0]);
    println(eq[0][1]);
    println(eq[1][0]);
    println(eq[1][1]);

    eq[0][0] === 0;
    eq[0][1] === 0;
    eq[1][0] === 0;
    eq[1][1] === 0;

    assert_eq(F[5], 5);
    assert_eq('F[5], 4);
    assert_eq('F[0], N-1);
    assert_eq(F[N-1]', 0);

    function foo(const expr e, int offset): const expr {
        expr res = 0;
        for (int i = 0; i < offset; i++) {
            res += (i)'e;
        }
        return res;
    }
}

airgroup ConstExprPrior {
    ConstExprPrior();
}
