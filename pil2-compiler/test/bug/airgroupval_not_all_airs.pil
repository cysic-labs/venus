airtemplate A(int N = 2**16) {
    container airgroup.std.A {
        airgroupval aggregate(prod) default(1) agvA;
    }
    use airgroup.std.A;
    col witness a;
    col witness b,c,d;

    a + 2 * b === c;
    agvA * (1 - agvA) === 0;
    on final airgroup final_agvA();
}
airtemplate B(int N = 2**16) {
    container airgroup.std.B {
        airgroupval aggregate(sum) default(0) agvB;
    }
    use airgroup.std.B;
    col witness a;
    col witness b,c,d;

    a * b + c === 0;
    on final airgroup final_agvB();
}

function final_agvB() {
    // println("final_agvB");
    container proof.myproof {
        expr gbus = 0;
    }
    use proof.myproof;
    use airgroup.std.B;
    gbus = gbus + agvB;
    on final proof final_proof();
}

function final_agvA() {
    // println("final_agvA");
    container proof.myproof {
        expr gbus = 0;
    }
    use proof.myproof;
    use airgroup.std.A;
    gbus = gbus + agvA;
    on final proof final_proof();
}

function final_proof() {
    // println("final_proof");
    use proof.myproof;
    #pragma dump gbus
    gbus === AA.agvA + BB.agvB;
}
airgroup AB {
    A();
    B();
}

airgroup AA {
    A() alias AA_A1;
    A() alias AA_A2;
}

airgroup BB {
    B() alias BB_B1;
    B() alias BB_B2;
}

airgroup BAB {
    B() alias BAB_B1;
    A() alias BAB_A;
    B() alias BAB_B2;
}

