#pragma test
int a = 23;
int b = 1;

int res;

res = a > 25 ? 1 : (1 - b);
assert(res == 0);

res = a > 15 ? 1 : (1 - b);
assert(res == 1);

a = 30;
res = a > 25 ? 1 : (1 - b);
assert(res == 1);

a = -1;
assert_eq(a, -1);

a = -(-(-2**8));
assert_eq(a, -256);

a = -2**8 + 1;
assert_eq(a, -255);

a = 2**3**4;
assert_eq(a, 2417851639229258349412352);

a = -3*2**8;
assert_eq(a, -768);

a = -(2)**8;
assert_eq(a, -256);


a = -2**7;
assert_eq(a, -128);

a = 0xF0;
b = a & 0x80 ? 1 : 0;
assert_eq(b, 1);

b = a & 0x80 ? 0 : 1;
assert_eq(b, 0);

a = 0x7F;
const int b3 = a & 0x80 ? 1 : 0;
assert_eq(b3, 0);

const int b4 = a & 0x80 ? 0 : 1;
assert_eq(b4, 1);


a = 0xF0;
b = (a & 0x80) ? 1 : 0;
assert_eq(b, 1);

b = (a & 0x80) ? 0 : 1;
assert_eq(b, 0);

a = 0x7F;
const int b1 = (a & 0x80) ? 1 : 0;
assert_eq(b1, 0);

const int b2 = (a & 0x80) ? 0 : 1;
assert_eq(b2, 1);

int k = 28;

a = 0xF0;
b = a & 0x80 ? 1 + k : 0;
assert_eq(b, 29);

b = a & 0x80 ? 0 : 1 + k;
assert_eq(b, 0);

a = 0x7F;
b = a & 0x80 ? 1 + k : 0;
assert_eq(b, 0);

b = a & 0x80 ? 0 : 1 + k;
assert_eq(b, 29);

a = 0xFF;
b = 1;
b = a & 0x80 ? 1 - b : b;
assert_eq(b, 0);

a = 0;
b = 1;
b = a & 0x80 ? 1 - b : b;
assert_eq(b, 1);

a = 0xFF;
b = 1;
b = a & 0x80 ? b : 1 - b;
assert_eq(b, 1);

a = 0;
b = 1;
b = a & 0x80 ? b : 1 - b;
assert_eq(b, 0);

a = 3;
b = 5;
int c2 = 8;
int d0 = c2 > a && a > 2 ? a * 2 + b * 7 : 5 * b - 3;
assert_eq(d0, 41);

int d1 = c2 < a && a > 2 ? a * 2 + b * 7 : 5 * b - 3;
assert_eq(d1, 22);

int d2 = c2 > a && a < 2 ? a * 2 + b * 7 : 5 * b - 3;
assert_eq(d2, 22);


function f(int c, expr sel):expr {
    expr _a = c ? sel : 0 - sel;
    return _a;
}

col witness w;
assert_eq(string(f(0, w * w)), "0 - w * w");
assert_eq(string(f(1, w * w)), "w * w");

const expr w1 = w*2 + k*w + 10;
const expr w2 = w*w*k + 1;

a = 10;
const expr _w1 = a > 0 ? w1 : w2;
assert_eq(string(_w1), `w * 2 + ${k} * w + 10`);

const expr __w1 = w2;
assert_eq(string(__w1), `w * w * ${k} + 1`);


const expr e1 = w;
const expr e2 = e1;
const expr e3 = e2;

const expr _e = a > 0 ? e3 : e1;
assert_eq(string(_e), "w");

const expr _e2 = a < 5 ? e3 : w * 2 + 8;
assert_eq(string(_e2), "w * 2 + 8");