airtemplate FoundInvalidContainerWithUse(int N = 2**6) {
    callme();
    testme();
}

function callme() {
    int opid = 10;
    container air.myfirstcon {
        int L = 30;        
        col witness l;
    }
    container air.myfirstcon.`id${opid}` {
        int L = 1030;
        col witness l2;
        int L2 = 20;
    }
}

function testme() {
    int opid = 10;
    int L2 = 23;

    assert_eq(L2, 23);

    use air.myfirstcon.`id${opid}`;

    assert_eq(L2, 23);
    assert_eq(air.myfirstcon.`id${opid}`.L2, 20);
    assert_eq(air.myfirstcon.id10.L2, 20);

    assert_eq(L, 1030);
    assert_eq(air.myfirstcon.`id${opid}`.L, 1030);
    assert_eq(air.myfirstcon.id10.L, 1030);
    assert_eq(air.myfirstcon.L, 30);
    assert_eq(string(l2), "FoundInvalidContainerWithUse.l2");

    {
        use air.myfirstcon;
        assert_eq(L, 30);
    }
}

airgroup FoundInvalidContainerWithUse {
    FoundInvalidContainerWithUse();
}