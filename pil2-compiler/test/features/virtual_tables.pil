airtemplate  TestVirtualVariable(int N = 2**16, int expected_value = 0, int deep = 1) {
    println(`VIRTUAL:${VIRTUAL}`);
    assert_eq(VIRTUAL, expected_value, "Virtual variable did not match expected value");
    if (deep > 0) {
        check_virtual_variable(expected_value, deep - 1);
    }
    assert_eq(VIRTUAL, expected_value, "Virtual variable did not match expected value");
}

int counter = 0;

function check_virtual_variable(int expected_value, int deep) {
    println(`check_virtual_variable: expected_value=${expected_value}, deep=${deep}`);
    assert_eq(VIRTUAL, expected_value, "Virtual variable did not match expected value");
    TestVirtualVariable(N, 0, 0) alias `T${counter}`;
    virtual TestVirtualVariable(N, 1, 0) alias `TV${counter}`;
    counter += 1;
}   

airtemplate TestCopy(int N = 2**16) {
    const int values[20];
    const int b = 18;

    col witness stage(2) tmp2;
    col fixed temporal(8) tmp = [0...];

    println(foo(10));
    virtualTables.hello(1, 2);
    println(`VIRTUAL:${VIRTUAL}`);
}

airtemplate TestFill(int N = 2**4, int num_groups = 2) {
    col fixed UID;
    int uid = 10;
    int h = 8;

    println("uid", uid);
    Tables.fill(uid, UID, 0, h);
    Tables.print(UID, 0, N);
}

airtemplate TestFillArray(int N = 2**4, int num_groups = 2) {
    col fixed UID[num_groups];
    int uid = 10;
    int h = 8;

    for (int i = 0; i < num_groups; ++i) {
        println("uid", uid);
        Tables.fill(uid + i, UID[i], 0, h);
        Tables.print(UID[i], 0, N);
    }
}   

airtemplate TestCopyArray(int N = 2**4) {
    col fixed PATTERN = [0..N-1];
    col fixed PATTERN2 = [1000000..(1000000 + N -1)];
    col fixed UID[2];
    int uid = 10;
    int h = 8;

    for (int i = 0; i < 2; ++i) {
        Tables.copy(PATTERN, i * h, UID[i], i*2, h);
        Tables.print(UID[i], 0, N);
    }
    for (int i = 0; i < 2; ++i) {
        Tables.copy(PATTERN2, i * h, UID[i], i*2, h);
        Tables.print(UID[i], 0, N);
    }
}   

airtemplate TestWriteAfterCopy(int N = 2**16) {
    col fixed F1 = [0..N-1];
    col fixed F2 = F1;

    assert_eq(F1[1], 1);
    assert_eq(F2[1], 1);

    F2[1] = N*2;

    assert_eq(F1[1], 1);
    assert_eq(F2[1], 2*N);
}


airtemplate TestWriteAfterPartialCopy(int N = 2**16) {
    col fixed F1 = [0..N-1];
    col fixed F2;

    assert_eq(F1[1], 1);
    assert_eq(F1[N-1], N-1);

    Tables.copy(F1, 0, F2, 16, N-16);

    assert_eq(F1[1], 1);
    assert_eq(F2[1], 0);
    assert_eq(F1[N-1], N-1);
    assert_eq(F2[N-1], N-16-1);
}

airtemplate TestReference(int N = 2**16) {
    col fixed F1 = [1..N];
    k = F1;
}


airtemplate TestTablesNumRows(int N = 2**16) {
    col fixed F1 = [1..N];
    col fixed temporal(80) F2;
    assert_eq(Tables.num_rows(F1), N);
    assert_eq(Tables.num_rows(F2), 80);
    Tables.copy(F1, 80, F2, 0, 80);
    k = F2;
}

airtemplate TestRecursiveA(int N = 2**16) {
    col fixed F1A = [9:N];
    col witness a;
    recursive_function();

    a + F1A === 0;    
    2*a + F1A === 0;    
}

airtemplate TestRecursiveB(int N = 2**16) {
    col witness b;
    col fixed F1B = [10:N];

    b + F1B === 0;
    2*b + F1B === 0;
}

function recursive_function() {
    TestRecursiveB();
}
expr k; 

airgroup TestVirtualTables {
    TestFill();
    TestFillArray();
    TestCopyArray();
