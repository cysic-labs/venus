function sum_1 (const int a = 0, const int b = 0):int {
    return 2 * a + b;
}

function sum_2 (const int a = 0, const int c = 0):int {
    return 2 * a + c;
}

function sum_array(const int a[] = [0,0], const int b[] = [0,0]):int {
    int res = 0;
    for (int i = 0; i < length(a); ++i) {
        res += a[i];
    }
    for (int i = 0; i < length(b); ++i) {
        res += b[i];
    }
    return res;
}

function count_array(const int a[] = [], const int b[] = []):int {
    int count = 0;
    for (int i = 0; i < length(a); ++i) {
        ++count;
    }
    for (int i = 0; i < length(b); ++i) {
        ++count;
    }
    return count;
}

airtemplate NamedParams(const int bits = 10,
                        const int N = 2**23) {

    if (!defined(inc)) {
        function inc (int a = 0, int b = 100, int c = 1000):int {
            int res = a + 2 * b + 4 * c;
            c = 8000;
            return res;
        }
    }
    
    println(bits);
    println(N);
}


airgroup NamedParams {
    NamedParams(bits: 12, N: 2**16);
    NamedParams(bits: 14, N: 2**18) alias NamedParams2;
    assert_eq(sum_1(10, 12), 32);
    int a = 7;
    int b = 9;
    assert_eq(sum_1(a, b), 23);
    assert_eq(sum_1(b, a), 25);
    assert_eq(sum_1(a:a, b:b), 23);
    assert_eq(sum_1(a, b:b), 23);
    assert_eq(sum_1(a:a), 14);
    assert_eq(sum_1(b:b), 9);
    assert_eq(sum_1(b:), 9);
    assert_eq(sum_1(a:,b:), 23);
    assert_eq(sum_1(b:,a:), 23);

    assert_eq(sum_2(a, b), 23);
    assert_eq(sum_2(a:a, c:b), 23);
    assert_eq(sum_2(a, c:b), 23);
    assert_eq(sum_2(a:a), 14);
    assert_eq(sum_2(c:b), 9);
    // assert_eq(sum_2(c:), 9);
    // assert_eq(sum_2(a:,b:), 23);
    // assert_eq(sum_2(a:,c:), 23);
    assert_eq(count_array(), 0);
    assert_eq(sum_array(), 0);
    assert_eq(count_array(a:[10]), 1);
    assert_eq(sum_array(a:[10]), 10);
    assert_eq(count_array(b:[10]), 1);
    assert_eq(sum_array(b:[10]), 10);
    assert_eq(count_array(a:[30], b:[10]), 2);
    assert_eq(count_array(a:[30,5], b:[10]), 3);
    assert_eq(sum_array(b:[10]), 10);
    assert_eq(sum_array(a:[30], b:[10]), 40);
    assert_eq(sum_array(a:[30,5], b:[10]), 45);
}

