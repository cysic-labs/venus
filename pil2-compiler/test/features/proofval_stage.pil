proofval stage(11) proofval_A11;
proofval proofval_A1;
proofval stage(2) proofval_A2;
proofval stage(2) proofval_A2_1;

proofval_A11 - 110 === 0;
proofval_A1 - 10 === 0;
proofval_A2 - 20 === 0;

airtemplate AirA(int N = 2**10, int type = 0) {
    col witness a,b,c,d;
    col fixed CTE = [1,0...];
    airval airval_A1;
    airval stage(11) airval_A2;
    airgroupval aggregate(prod) agvA;
    airval_A2 * (1 - airval_A2) === 0;

}

airtemplate AirB(int N = 2**10) {
    col witness stage(4) a,b[5][3][2][1];
    airval stage(13) airval_B1[5][4][3][2][1];
    airgroupval aggregate(prod) stage(11) agvB;
    agvB - a*b[0][0][0][0]=== 0;
    airval_B1[0][0][0][0][0] * (4 - airval_B1[0][0][0][0][0]) === 0;

}

airgroup A {
    int rows = 2**3;
    AirA(rows, 0);
}
airgroup B {
    int rows = 2**3;
    AirB(rows, 0) alias B1;
    AirB(rows, 0) alias B2;
}
