public k;
public kv[2];
proofval pf;
challenge stage(1) ch;

airtemplate Degree(int N = 2**10) {
    col witness a,b,c,d;
    col fixed L1 = [1,0...];

    airgroupval aggregate(sum) gsum;
    airval val;
    assert_eq(degree(a), 1);
    assert_eq(degree(L1), 1);
    assert_eq(degree(0), 0);
    assert_eq(degree(k), 0);
    assert_eq(degree(kv[1]) , 0);
    assert_eq(degree(kv), -1);
    assert_eq(degree(gsum), 0);
    assert_eq(degree(val), 0);
    assert_eq(degree(pf), 0);
    assert_eq(degree(ch), 0);
    assert_eq(degree(kv), -1);
    assert_eq(degree(k*3), 0);
    assert_eq(degree(a*a), 2);
    assert_eq(degree(a*L1), 2);
    assert_eq(degree(a*L1*a), 3);
    assert_eq(degree((1 + a*L1)*(b+c)), 3);
    assert_eq(degree(a*k), 1);
    assert_eq(degree(3*a), 1);
    assert_eq(degree(a+a), 1);
    assert_eq(degree(a+L1), 1);
    assert_eq(degree(a+k), 1);
    assert_eq(degree(3+a), 1);
    assert_eq(degree(1+k), 0);
    assert_eq(degree(1+k*k+a*a+b*b*b), 3);
    expr e = a * b;
    assert_eq(degree(e), 2);
    assert_eq(degree(e*a), 3);
    const expr ce = a * b;
    assert_eq(degree(ce), 2);
    assert_eq(degree(a*a*a), 3);
    assert_eq(degree(a*ce*ce*a), 6);
    myfunc(a, a*a, a*a*a);
    myfunc(a, ce, e*a+e*k+e, 10);
}

function myfunc(const expr e1, expr e2, expr e3, int value = 3) {
    assert_eq(degree(value), 0);
    assert_eq(degree(e1), 1);
    assert_eq(degree(e2), 2);
    assert_eq(degree(e3), 3);
}

airgroup Degree {
    Degree();
}
