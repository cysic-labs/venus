proofval rom_root1;
public rom_root[4];
public usualops_root[4];

commit stage(18) public(usualops_root) usualops;
// ERROR: commit public(usualops_root) usualops3;
commit stage(9) usualops2;

airtemplate CommitTest(int N = 2**13) {
    commit public(rom_root) rom;
    commit stage(13) rom2;
    col rom stage(2) line;
    col rom stage(2) line2;
    col usualops values;
    col usualops2 values2;
    col rom2 instruction;
    col rom2 instruction2;

    instruction === instruction2 ;
    line + line2 + 10 === 0;
    values + 12 === 0;
    values2 + 10 === 0;
}


airtemplate CommitTest2(int N = 2**13) {
    commit rom;
    commit stage(11) rom2;
    col rom stage(2) line;
    col rom2 instruction;
    // col usualops values;
    col usualops2 values2;

    instruction - 20 === 0;
    line + 10 === 0;
    values2 + 15 === 0;
}

airgroup Commit {
    CommitTest();
    CommitTest2();
}