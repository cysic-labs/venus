function foo(int a):int {
    return a + 2;
}   

assert_eq(foo(10), 12);

function sum(int a, int b): int {
    return a + b;
}

package FooPackage {
    function sum(int a, int b): int {
        return a + b + 2;
    }
    public function foo(int a):int {
        return sum(a, a*4);
    }

    public function bar(int a):int {
        return a * 3;
    }   
}

use FooPackage;

assert_eq(FooPackage.foo(11), 57);
assert_eq(foo(11), 13);
assert_eq(sum(11, 44), 55);
assert_eq(bar(11), 33); 